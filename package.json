  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsx": "^4.19.4",
    "typescript": "^5"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "mcppedia",
    "ai",
    "llm"
  ]
